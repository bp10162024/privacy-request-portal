<%
const statusBadge = (s) => {
  if (s === 'completed') return 'badge-green';
  if (s === 'in_progress') return 'badge-blue';
  if (s === 'failed') return 'badge-red';
  if (s === 'skipped' || s === 'not_applicable') return 'badge-gray';
  return 'badge-yellow';
};
%>
<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold"><%= req.requester_email %></h1>
    <p class="text-slate-600 text-sm">Logged <%= new Date(req.date_received).toLocaleString() %> by <%= req.created_by %></p>
  </div>
  <a href="/" class="text-slate-600 hover:underline text-sm">← Back to dashboard</a>
</div>

<div class="grid grid-cols-3 gap-4 mb-6">
  <div class="bg-white rounded p-4">
    <div class="text-slate-500 text-xs uppercase">Type</div>
    <div class="font-bold"><%= req.request_type.replace('_',' ') %></div>
  </div>
  <div class="bg-white rounded p-4">
    <div class="text-slate-500 text-xs uppercase">Status</div>
    <div class="font-bold"><%= req.status.replace('_',' ') %></div>
  </div>
  <div class="bg-white rounded p-4">
    <div class="text-slate-500 text-xs uppercase">Deadline</div>
    <div class="font-bold"><%= new Date(req.deadline_at).toLocaleDateString() %></div>
  </div>
</div>

<% if (req.source_url) { %>
  <div class="mb-4">
    <a href="<%= req.source_url %>" target="_blank" class="text-blue-600 hover:underline text-sm">→ Open source (<%= req.source %>)</a>
  </div>
<% } %>

<% if (req.notes) { %>
  <div class="bg-yellow-50 border border-yellow-200 rounded p-4 mb-6">
    <div class="text-xs uppercase text-slate-500 mb-1">Notes</div>
    <div><%= req.notes %></div>
  </div>
<% } %>

<div class="bg-white rounded-lg shadow mb-6">
  <div class="px-6 py-4 border-b flex items-center justify-between">
    <h2 class="font-bold">Third-party actions</h2>
    <% if (req.status !== 'completed' && req.status !== 'cancelled') { %>
      <form method="POST" action="/requests/<%= req.id %>/run-all" class="inline">
        <button type="submit" class="bg-slate-900 text-white px-4 py-2 rounded text-sm">
          Run All Automated
        </button>
      </form>
    <% } %>
  </div>

  <table class="w-full text-sm">
    <thead class="bg-slate-50 text-slate-700">
      <tr>
        <th class="px-6 py-2 text-left">Destination</th>
        <th class="px-6 py-2 text-left">Status</th>
        <th class="px-6 py-2 text-left">Last action</th>
        <th class="px-6 py-2 text-left">Notes</th>
        <th class="px-6 py-2 text-right"></th>
      </tr>
    </thead>
    <tbody>
      <% actions.forEach(a => { %>
        <tr class="border-t">
          <td class="px-6 py-3">
            <div class="font-medium"><%= a.label %></div>
            <% if (a.docs) { %>
              <a href="<%= a.docs %>" target="_blank" class="text-blue-600 hover:underline text-xs">docs</a>
            <% } %>
          </td>
          <td class="px-6 py-3">
            <span class="badge <%= statusBadge(a.status) %>"><%= a.status %></span>
            <% if (!a.automated) { %>
              <div class="text-xs text-slate-500 mt-1">manual</div>
            <% } %>
          </td>
          <td class="px-6 py-3 text-slate-500 text-xs">
            <%= a.executed_at ? new Date(a.executed_at).toLocaleString() : '—' %>
            <% if (a.executed_by) { %><br><%= a.executed_by %><% } %>
          </td>
          <td class="px-6 py-3 text-xs text-slate-600 max-w-md">
            <% if (a.error_message) { %>
              <span class="text-red-600"><%= a.error_message %></span>
            <% } else if (a.response_data && a.response_data.notes) { %>
              <%= a.response_data.notes %>
            <% } else if (a.external_reference) { %>
              ref: <%= a.external_reference %>
            <% } %>
          </td>
          <td class="px-6 py-3 text-right whitespace-nowrap">
            <% if (a.automated && a.status !== 'completed') { %>
              <form method="POST" action="/requests/<%= req.id %>/run/<%= a.destination %>" class="inline">
                <button type="submit" class="bg-blue-600 text-white px-3 py-1 rounded text-xs hover:bg-blue-700">
                  Run
                </button>
              </form>
            <% } %>
            <% if (!a.automated && a.status !== 'completed') { %>
              <form method="POST" action="/requests/<%= req.id %>/manual-complete/<%= a.destination %>" class="inline">
                <button type="submit" class="bg-green-600 text-white px-3 py-1 rounded text-xs hover:bg-green-700">
                  Mark done
                </button>
              </form>
            <% } %>
            <% if (a.status === 'completed') { %>
              <span class="text-green-600 text-xs">✓ Done</span>
            <% } %>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<% if (allDone && req.status !== 'completed') { %>
  <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
    <h3 class="font-bold mb-2">All destinations complete</h3>
    <p class="text-sm text-slate-700 mb-4">Ready to mark this request complete and send the confirmation email to <strong><%= req.requester_email %></strong>.</p>
    <form method="POST" action="/requests/<%= req.id %>/complete" class="inline">
      <button type="submit" class="bg-green-700 text-white px-4 py-2 rounded">Mark Complete + Send Confirmation</button>
    </form>
  </div>
<% } %>

<div class="bg-white rounded-lg shadow">
  <div class="px-6 py-4 border-b">
    <h2 class="font-bold">Audit log</h2>
  </div>
  <ul class="text-sm">
    <% auditLog.forEach(a => { %>
      <li class="px-6 py-2 border-t flex items-center justify-between">
        <span><code class="text-xs"><%= a.action %></code> <span class="text-slate-500"><%= a.actor_email %></span></span>
        <span class="text-slate-500 text-xs"><%= new Date(a.created_at).toLocaleString() %></span>
      </li>
    <% }); %>
    <% if (auditLog.length === 0) { %>
      <li class="px-6 py-4 text-slate-500 text-center">No audit entries yet.</li>
    <% } %>
  </ul>
</div>
